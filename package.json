{
  "name": "vande-bharat-poc",
  "private": true,
  "scripts": {
    "start":    "concurrently -n BACKEND,YOLO,OCR,FRONTEND -c bgBlue.bold,bgYellow.bold,bgMagenta.bold,bgGreen.bold \"npm run backend\" \"npm run yolo\" \"npm run ocr\" \"npm run frontend\"",
    "backend":  "cd backend && venv\\Scripts\\python.exe -m uvicorn main:app --reload --port 8000",
    "yolo":     "cd backend/YOLO && venv\\Scripts\\python.exe server.py",
    "ocr":      "cd backend/OCR && venv\\Scripts\\python.exe server.py",
    "frontend": "cd ui && npm run dev"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
