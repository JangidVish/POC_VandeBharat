{
  "name": "vande-bharat-ocr",
  "version": "1.0.0",
  "description": "Unified OCR Benchmarking Pipeline",
  "main": "server.py",
  "scripts": {
    "server": ".\\venv\\Scripts\\python server.py",
    "client": "npm run dev --prefix frontend",
    "dev": "concurrently -n \"BACKEND,FRONTEND\" -c \"blue,magenta\" \"npm run server\" \"npm run client\"",
    "install-all": "npm install && npm install --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
